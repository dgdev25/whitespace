# Database (SQLite for dev, PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:///./whitespace.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/whitespace

RUVECTOR_BASE_URL=http://localhost:18732
EMBEDDINGS_MODE=full

# LLM runner — first available key wins
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=AI...
# OPENROUTER_API_KEY=sk-or-...

# GitHub token (optional — increases rate limit from 60 to 5000 req/hr)
# GITHUB_TOKEN=ghp_...

# CORS allowed origins (comma-separated, defaults to localhost dev)
CORS_ORIGINS=http://localhost:18731

PIPELINE_MODE=full
WORKER_SCHEDULE_HOUR=2
WORKER_SCHEDULE_MINUTE=0
ARXIV_ORGS=DeepMind,Anthropic,OpenAI
ARXIV_CATEGORIES=cs.LG,cs.AI,cs.SE,cs.HC,cs.AR,cs.DC,eess.SP
IDEAS_PER_RUN=8
